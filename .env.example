# Optional: workspace root (parent of annotator/, sam3/, sam2/, MedSAM3/, videos/)
# WORKSPACE_ROOT=/path/to/workspace

# SAM3 (facebookresearch/sam3 checkout)
# SAM3_REPO=/path/to/sam3
# SAM3_CHECKPOINT=/path/to/sam3/checkpoints/sam3.pt
# SAM3_BPE=/path/to/sam3/sam3/assets/bpe_simple_vocab_16e6.txt.gz

# SAM2 / MedSAM2-style checkout with configs/
# SAM2_REPO=/path/to/sam2
# SAM2_CHECKPOINT=/path/to/sam2/checkpoints/sam2.1_hiera_tiny.pt
# SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_t.yaml

# MedSAM3 (Joey-S-Liu/MedSAM3) — only for medsam3 server
# MEDSAM3_REPO=/path/to/MedSAM3
# MEDSAM3_LORA_CONFIG=/path/to/MedSAM3/configs/full_lora_config.yaml
# MEDSAM3_LORA_WEIGHTS=/path/to/MedSAM3/weights/best_lora_weights.pt

# Input videos directory (served read-only at /videos-raw)
# VIDEOS_DIR=/path/to/videos

# Frame cache (writable)
# FRAMES_SAM3=/tmp/sam3_annotator
# FRAMES_MEDSAM3=/tmp/medsam3_annotator
